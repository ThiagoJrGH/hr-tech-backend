# Configuración del Servidor
PORT=3000
NODE_ENV="development"

# URL de la base de datos SQL Server (Ejemplo con Windows Auth)
DATABASE_URL="sqlserver://localhost:1433;database=HrTechDB;integratedSecurity=true;trustServerCertificate=true"

# Seguridad JWT
JWT_SECRET="mi_super_secreto_indescifrable_123"
JWT_EXPIRES_IN="1d"

# Frontend
CORS_ORIGIN="http://localhost:5173"

# Inteligencia Artificial (Google Gemini)
GEMINI_API_KEY="tu_api_key_de_google_aqui"

# PINNED VERSION: Fijamos la versión exacta (2.5) en lugar de usar 'latest'. 
# Esto garantiza estabilidad y evita que actualizaciones automáticas de Google rompan las respuestas de la IA.
GEMINI_MODEL="gemini-2.5-flash"

# Timeout para respuestas de la IA (15 segundos)
GEMINI_TIMEOUT_MS=15000